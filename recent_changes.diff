+            LIMIT 6
+        `, [businessId, searchTerm, searchTerm, searchTerm, searchTerm]);
+
+        console.log("=== DB Queries execution successful! ===");
+        process.exit(0);
+    } catch (err) {
+        console.error("Verification failed:", err);
+        process.exit(1);
+    } finally {
+        await pool.end();
+    }
+}
+
+run();
