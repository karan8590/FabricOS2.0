+                i.invoice_number ILIKE ? OR
+                c.name ILIKE ? OR
+                c.gstin ILIKE ?
+            )
+            ORDER BY i.id DESC
+            LIMIT 6
+        `, [businessId, searchTerm, searchTerm, searchTerm]);
