+/* ===================================================
+   Redesigned Production View CSS
+   =================================================== */
+
+.container {
+    max-width: 600px;
+    margin: 0 auto;
+    padding: 16px 16px 100px 16px;
+    min-height: 100vh;
+    display: flex;
+    flex-direction: column;
+}
+
+.header {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    margin-bottom: 16px;
+}
+
+.headerTitleGroup {
+    display: flex;
+    align-items: center;
+    gap: 12px;
+}
+
+.headerIcon {
+    width: 42px;
+    height: 42px;
+    border-radius: 12px;
+    background: rgba(99, 102, 241, 0.1);
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    color: #6366F1;
+}
+
+.headerTextGroup {
+    display: flex;
+    flex-direction: column;
+}
+
+.title {
+    font-size: 24px;
+    font-weight: 800;
+    color: var(--text-primary, #1F2937);
+    margin: 0;
+    letter-spacing: -0.5px;
+}
+
+.subtitle {
+    font-size: 13px;
+    color: var(--text-tertiary, #6B7280);
+    margin: 2px 0 0 0;
+    font-weight: 500;
+}
+
+.refreshBtn {
+    width: 40px;
+    height: 40px;
+    border-radius: 12px;
+    border: 1px solid var(--border-primary, #E5E7EB);
+    background: var(--bg-card, #FFF);
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    cursor: pointer;
+    color: var(--text-secondary, #4B5563);
+    transition: all 0.2s ease;
+}
+
+.refreshBtn:active {
+    transform: scale(0.95);
+}
+
+.refreshing {
+    animation: spin 1s linear infinite;
+}
+
+/* Horizontal tab bar styles */
+.tabBarContainer {
+    position: sticky;
+    top: 0;
+    z-index: 10;
+    background: var(--bg-body, #F9FAFB);
+    margin: 0 -16px 20px -16px;
+    padding: 8px 16px;
+    border-bottom: 1px solid var(--border-primary, #E5E7EB);
+    display: flex;
+    gap: 8px;
+    overflow-x: auto;
+    scrollbar-width: none; /* Hide scrollbar Firefox */
+}
+
+.tabBarContainer::-webkit-scrollbar {
+    display: none; /* Hide scrollbar Chrome/Safari */
+}
+
