new file mode 100644
index 0000000..bcf468d
--- /dev/null
+++ b/components/layout/MobileBottomNav.module.css
@@ -0,0 +1,116 @@
+/* ===================================================
+   MobileBottomNav — 5-tab native bottom navigation
+   =================================================== */
+
+.bottomNav {
+    display: none; /* hidden on desktop */
+}
+
+@media (max-width: 768px) {
+    .bottomNav {
+        display: flex;
+        align-items: stretch;
+        position: fixed;
